# Neon connection string (Settings -> Connection string no console do Neon)
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require"

# String aleatória longa (ex: openssl rand -base64 48) usada pra assinar os JWTs de staff
JWT_SECRET=""

# Opcional: origens permitidas por CORS, separadas por vírgula. Se vazio, permite qualquer origem (*)
ALLOWED_ORIGINS=
