// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Um registro por hotel. `config` é o antigo tenant_config.json inteiro
/// (hotelInfo, colorPalette, typography, buttonStyles, navigationItems,
/// servicesList, homePage, promoImages...). Sem duplicar o nome do hotel
/// numa coluna separada — é lido de dentro do jsonb quando necessário
/// (ex: no endpoint de diretório).
model Hotel {
  id           String         @id // "hotel_1", "hotel_2"
  config       Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  content      HotelContent[]
  staff        Staff[]
  services     Service[]
  staffInvites StaffInvite[]
  guests       Guest[]
  orders       Order[]
  stays        Stay[]

  @@map("hotels")
}

/// Uma linha por "página" por hotel — substitui hotels/{hotelId}/content/{docName}.
/// docName é texto livre (não enum): o lado Flutter já trata isso como um
/// conjunto aberto de chaves de página.
model HotelContent {
  hotelId   String
  docName   String
  data      Json
  updatedAt DateTime @updatedAt
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@id([hotelId, docName])
  @@map("hotel_content")
}

enum StaffRole {
  gerente
  recepcao
}

/// Autenticação de staff — o único ponto que vale normalizar (e-mail precisa
/// de unicidade, hotelId/role precisam ser consultados e devolvidos em toda
/// requisição de login/me).
model Staff {
  id           String    @id @default(cuid())
  hotelId      String
  email        String    @unique
  passwordHash String
  role         StaffRole
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  hotel        Hotel     @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@map("staff")
}

/// Convite pra uma nova conta de staff se cadastrar como `recepcao` de um
/// hotel específico, sem precisar de um `gerente` criando a conta na mão.
/// `role` fica travado em `recepcao` pela rota que cria o convite (Task
/// 13) — não é um campo livre que o cliente possa escolher.
model StaffInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  hotelId   String
  role      StaffRole @default(recepcao)
  consumed  Boolean   @default(false)
  createdAt DateTime  @default(now())
  hotel     Hotel     @relation(fields: [hotelId], references: [id])

  @@index([hotelId])
  @@map("staff_invites")
}

enum StayStatus {
  active
  closed
}

/// Reserva de um quarto — agrupa um ou mais hóspedes (marido, esposa,
/// filhos) sob a mesma estadia. `roomNumber`/`checkInDate`/`checkOutDate`
/// vivem aqui (não em `Guest`) porque são dados do QUARTO, compartilhados
/// por todo mundo que está nele; cada `Guest` individual só guarda seus
/// próprios dados pessoais + código de acesso.
///
/// "Fechar a conta" = marcar `status: closed` e revogar (`status: revoked`)
/// o `accessCode` de todos os `Guest` da estadia de uma vez — feito em
/// `PATCH /api/hotels/:hotelId/stays/:stayId`.
model Stay {
  id           String       @id @default(cuid())
  hotelId      String
  roomNumber   String
  checkInDate  DateTime
  checkOutDate DateTime
  status       StayStatus   @default(active)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  hotel        Hotel        @relation(fields: [hotelId], references: [id])
  guests       Guest[]
  notices      StayNotice[]

  @@index([hotelId])
  @@map("stays")
}

/// Aviso da recepção pra todos os hóspedes de uma estadia — só leitura
/// (o hóspede visualiza, não responde). Um chat de verdade fica pra uma
/// fase futura separada.
model StayNotice {
  id        String   @id @default(cuid())
  stayId    String
  message   String
  createdAt DateTime @default(now())
  stay      Stay     @relation(fields: [stayId], references: [id], onDelete: Cascade)

  @@index([stayId])
  @@map("stay_notices")
}

enum GuestStatus {
  active
  revoked
}

enum DocumentType {
  cpf
  passport
  other
}

/// Hóspede individual de um hotel — cadastro completo (nome, documento,
/// contato), sempre vinculado a uma `Stay` (o quarto/estadia que ele
/// compartilha com o resto da família). Substitui o código único-por-hotel
/// (compartilhado por qualquer pessoa) por um código pessoal que a
/// recepção pode revogar no check-out. `status: revoked` em vez de apagar
/// a linha — preserva o registro pra Pedidos (um pedido referencia um
/// Guest).
///
/// `accessCode` é prefixado com uma tag derivada do próprio `hotelId` (ex:
/// "HOTEL1-8F3A2B1C") — puramente pra deixar auditável/visível de qual
/// hotel é cada código a olho nu; a unicidade em si já é garantida pela
/// constraint `@unique` sozinha, independente do prefixo.
///
/// `wifiPassword: null` = usa a senha padrão do hotel (vinda do doc
/// `guestInfo` em HotelContent) — só sobrescreve quando o hotel quer dar
/// uma senha individual pra esse hóspede.
model Guest {
  id                  String       @id @default(cuid())
  hotelId             String
  stayId              String
  firstName           String
  lastName            String
  documentType        DocumentType
  documentNumber      String
  phoneCountryCode    String
  phoneNumber         String
  whatsappCountryCode String?
  whatsappNumber      String?
  email               String?
  address             String?
  country             String
  wifiPassword        String?
  accessCode          String       @unique
  status              GuestStatus  @default(active)
  createdAt           DateTime     @default(now())
  hotel               Hotel        @relation(fields: [hotelId], references: [id])
  stay                Stay         @relation(fields: [stayId], references: [id])
  orders              Order[]

  @@index([hotelId])
  @@index([stayId])
  @@map("guests")
}

enum OrderStatus {
  pending
  in_progress
  completed
  cancelled
}

/// Pedido de um hóspede referenciando um `ServiceItem` qualquer — sem
/// distinção por "tipo" (room service, spa, etc.), já que o catálogo em si
/// é genérico desde a Fase 4. `itemName`/`price` são um snapshot no
/// momento do pedido: sobrevivem a uma edição ou remoção do item depois.
model Order {
  id            String      @id @default(cuid())
  hotelId       String
  guestId       String
  serviceId     String
  serviceItemId String
  itemName      String
  quantity      Int         @default(1)
  price         Float?
  status        OrderStatus @default(pending)
  note          String?
  /// Data/hora escolhida pelo hóspede — só preenchido pra itens que passam
  /// pelo fluxo de agendamento (restaurantes, spa, eventos, passeios).
  /// `null` pra pedidos de Serviço de Quarto, que não têm horário marcado.
  scheduledFor  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  hotel         Hotel       @relation(fields: [hotelId], references: [id])
  guest         Guest       @relation(fields: [guestId], references: [id])

  @@index([hotelId])
  @@index([guestId])
  @@map("orders")
}

/// Substitui konektoBrand/{docId} — tabela global (não específica de hotel),
/// hoje só usada pra "promotions".
model BrandContent {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("brand_content")
}

enum ServiceType {
  /// Cardápio pedido pro quarto — item por item, com quantidade e
  /// observação (app do hóspede usa o fluxo de "Adicionar ao pedido").
  room_service
  /// O cardápio é só informativo; a reserva é da MESA do restaurante como
  /// um todo (um botão único abaixo da lista de itens), não por prato.
  restaurant
  /// Qualquer experiência agendável item a item (spa, eventos, passeios,
  /// ou algo novo que o hotel crie) — cada item abre o modal de dia/hora.
  activity
}

/// Serviço criado pelo hotel (Room Service, Spa, um restaurante específico,
/// ou algo totalmente novo como "Aluguel de Bicicleta") — substitui os 5
/// tipos fixos que existiam antes no código. Cada restaurante é seu próprio
/// Service (não um Service "Restaurantes" com um nível extra dentro).
///
/// `type` decide o COMPORTAMENTO no app do hóspede (ver [ServiceType]) —
/// só 3 valores possíveis, definido na criação e não muda depois (trocar o
/// comportamento de um serviço já em uso não faz sentido operacional,
/// mesmo padrão do `slug` imutável).
///
/// `category` é o rótulo livre que agrupa o serviço na lista do portal
/// (ex: "Restaurante", "Lavanderia", "Transfer") — o hotel pode criar
/// quantas categorias quiser; cada uma delas escolhe um dos 3 `type`
/// por trás. Diferente de `type`, `category` pode ser editada depois
/// (é só organização visual, não muda nada no app).
model Service {
  id             String        @id @default(cuid())
  hotelId        String
  name           String
  slug           String
  icon           String // nome do ícone Material (ex: "room_service", "spa", "restaurant")
  description    String
  type           ServiceType
  category       String
  bannerImageUrl String?
  position       Int           @default(0)
  enabled        Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  hotel          Hotel         @relation(fields: [hotelId], references: [id])
  items          ServiceItem[]

  @@unique([hotelId, slug])
  @@index([hotelId])
  @@map("services")
}

/// Item de um serviço (prato do cardápio, tratamento de spa, evento,
/// passeio...). `price: null` = não é "comprável" (eventos/passeios só têm
/// "solicitar"/"reservar", sem preço) — a UI decide o que mostrar com base
/// nisso, sem precisar de um campo separado tipo "buttonText".
///
/// `hidden: true` marca um item técnico/sintético que nunca aparece em
/// nenhuma listagem (portal ou app do hóspede) — hoje só usado pro item
/// "Reserva de mesa" auto-criado por trás de um `Service` do tipo
/// `restaurant`, pra reaproveitar o modelo `Order` existente sem precisar
/// de uma tabela nova só pra reservas de mesa.
model ServiceItem {
  id          String   @id @default(cuid())
  serviceId   String
  name        String
  description String
  price       Float?
  imageUrl    String?
  location    String? // usado por eventos/passeios
  category    String? // agrupamento opcional (usado por room service: Entradas/Pratos/etc.)
  extraInfo   String? // rótulo livre (tempo de preparo, duração, etc.)
  position    Int      @default(0)
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_items")
}
