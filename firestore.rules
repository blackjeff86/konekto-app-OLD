rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Marca Konekto (promoções da tela de acesso) — mesma lógica: já
    // ship dentro do app hoje, leitura pública não é uma exposição nova.
    match /konektoBrand/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Hotel branding/content é público-leitura por enquanto — isso espelha
    // a realidade de hoje (já vai empacotado dentro do app pra todo
    // dispositivo). Sem escrita ainda: staff auth + papéis vêm numa fase
    // posterior.
    match /hotels/{hotelId} {
      allow read: if true;
      allow write: if false;

      // Cada página (cardápio, restaurantes, spa, eventos, passeios, mapa,
      // etc.) fica num documento único em `content/{docName}` nesta
      // primeira fase — ver nota em firestore_tenant_repository.dart sobre
      // por que não explodimos em documentos por item ainda.
      match /content/{docName} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Everything sensitive (guests, orders, conversations, staff, invites)
    // stays fully locked down until the auth/claim flow lands.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
